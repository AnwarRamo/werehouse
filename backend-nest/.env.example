PORT=5001
NODE_ENV=development
QUEUES_ENABLED=true
JWT_SECRET=change_me
JWT_EXPIRE=15m
JWT_COOKIE_NAME=warehouse_access_token
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAME_SITE=lax
JWT_COOKIE_MAX_AGE_MS=900000
JWT_ROTATE_THRESHOLD_SEC=300

# Database (Prisma + PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/warehouse_system?sslmode=verify-full

# Queue/worker backend
REDIS_URL=redis://127.0.0.1:6379
# Required in production: auth token revocation runs in fail-closed mode.

# Optional CORS override (comma-separated origins). Keep empty for same-origin only in dev.
CORS_ORIGIN=

# Security switches (recommended production values shown)
JWT_ALLOW_BEARER=false
AUTH_RETURN_TOKEN_IN_BODY=false
TRUST_PROXY=true

