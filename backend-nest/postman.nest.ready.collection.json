    "description": "Validated collection for auth, employees, devices, attendance, inventory, payroll, and imports.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001/api" },
    { "key": "username", "value": "admin" },
    { "key": "password", "value": "password123" },
    { "key": "token", "value": "" },
    { "key": "roleId", "value": "" },
    { "key": "employeeId", "value": "EMP900001" },
    { "key": "deviceId", "value": "DEV900001" },
    { "key": "attendanceId", "value": "" },
    { "key": "sku", "value": "SKU-TEST-001" },
    { "key": "productId", "value": "" },
    { "key": "payrollRunId", "value": "" },
    { "key": "importJobId", "value": "" }
  ],
  "item": [
    {
      "name": "01 Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "02 Auth",
      "item": [
        {
          "name": "POST Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login 200', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "if (data.token) { pm.collectionVariables.set('token', data.token); }"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "GET Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "GET Roles (save roleId)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('roles 200', function () { pm.response.to.have.status(200); });",
                  "const roles = pm.response.json();",
                  "if (Array.isArray(roles) && roles.length > 0) { pm.collectionVariables.set('roleId', roles[0].id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/roles"
          }
        }
      ]
    },
